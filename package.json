{
  "name": "lone-wolf",
  "version": "0.0.0",
  "private": true,
  "description": "Lobo Solitario, libro 1 (Huida de la Oscuridad), como webapp interactiva",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter \"./apps/*\" dev",
    "build": "pnpm -r build",
    "build:api": "esbuild apps/api/handler.ts --bundle --platform=node --format=cjs --outfile=api/handler.js",
    "lint": "biome ci .",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@vercel/node": "^5.8.17",
    "esbuild": "^0.25.0"
  }
}
