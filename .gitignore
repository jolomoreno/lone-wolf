# Dependencias
node_modules/
.pnpm-store/

# Builds
dist/
build/
*.tsbuildinfo

# Bundle serverless generado por esbuild (artefacto de build, no se versiona)
api/handler.js

# Variables de entorno (¡nunca subir secretos!)
.env
.env.*
!.env.example

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# Caché de herramientas
.vite/
coverage/

# Sistema operativo / editor
.DS_Store
.idea/
.vscode/*
!.vscode/extensions.json

# Configuración local de Claude Code (específica de la máquina)
.claude/settings.local.json

# Vercel (generado por vercel link — contiene IDs del proyecto, no secretos,
# pero es específico de la máquina y no debe compartirse en el repo)
.vercel/

# Contenido del libro (Project Aon): no se redistribuye en el repo
data/*.xml
