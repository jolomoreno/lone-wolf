# Copia este archivo a ".env" y rellena los valores.
# El ".env" real NO se sube a git (está en .gitignore).

# Puerto en el que escucha la API
PORT=4000

# Cadena de conexión a MongoDB (Atlas o local).
# Déjala vacía para arrancar el servidor SIN base de datos.
MONGODB_URI=

# Origen permitido para CORS (la URL del frontend en desarrollo, Vite usa 5173)
CORS_ORIGIN=http://localhost:5173

# Entorno: development | production
NODE_ENV=development
